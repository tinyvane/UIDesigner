    },
    {
      "type": "border_decoration", "name": "边框",
      "x": 20, "y": 10, "width": 1880, "height": 1060,
      "props": { "borderColor": "#92400e", "borderWidth": 1, "cornerSize": 20, "style": "tech" }
    }
  ]
