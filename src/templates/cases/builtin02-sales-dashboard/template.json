{
  "id": "builtin02-sales-dashboard",
  "name": "销售业绩看板",
  "nameEn": "Sales Performance Dashboard",
  "description": "深色主题销售业绩看板，包含营收统计卡片、月度营收柱状图、产品分布饼图、日销售趋势折线图、销售排名表",
  "descriptionEn": "Dark-themed sales performance dashboard with revenue stat cards, monthly revenue bar chart, product distribution pie chart, daily sales trend line chart, and sales ranking table",
  "source": "内置模板",
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": { "type": "color", "value": "#111827" }
  },
  "components": [
