    },
    {
      "type": "stat_card", "name": "客单价",
      "x": 960, "y": 120, "width": 440, "height": 160,
      "props": { "title": "平均客单价", "value": "¥ 1,289", "trend": 5.9, "trendLabel": "同比增长", "color": "#8b5cf6" }
    },
    {
      "type": "stat_card", "name": "回款率",
      "x": 1420, "y": 120, "width": 460, "height": 160,
      "props": { "title": "回款率", "value": "94.3%", "trend": 2.1, "trendLabel": "较上月", "color": "#10b981" }
    },
    {
      "type": "chart_bar", "name": "月度营收",
      "x": 40, "y": 320, "width": 900, "height": 340,
      "props": { "title": "月度营收趋势 (万元)", "color": "#f59e0b", "data": { "categories": ["1月","2月","3月","4月","5月","6月","7月","8月","9月","10月","11月","12月"], "values": [1850,1620,2100,1980,2250,2480,2150,2380,2560,2420,2180,2385] }, "showGrid": true, "gradient": true, "gradientFrom": "#92400e", "gradientTo": "#f59e0b", "barRadius": 4 }
    },
    {
      "type": "chart_pie", "name": "产品分布",
      "x": 960, "y": 320, "width": 920, "height": 340,
      "props": { "title": "产品销售分布", "donut": true, "data": [{ "name": "企业版", "value": 4200 }, { "name": "专业版", "value": 3800 }, { "name": "标准版", "value": 2600 }, { "name": "基础版", "value": 1500 }, { "name": "试用版", "value": 800 }] }
    },
    {
      "type": "chart_line", "name": "日销售额",
      "x": 40, "y": 700, "width": 900, "height": 340,
      "props": { "title": "近30日销售额趋势", "color": "#06b6d4", "smooth": true, "areaFill": true, "data": { "categories": ["1日","5日","10日","15日","20日","25日","30日"], "values": [82,95,78,110,125,108,130] } }
